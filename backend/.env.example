PORT=3001
REFRESH_MS=60000
KAGGLE_CMD=kaggle

# Admin (legacy shared token; кепт как fallback для CI/скриптов).
ADMIN_TOKEN=

# Identity
DB_FILE=./data/app.db
SESSION_TTL_DAYS=30
COOKIE_SECURE=auto

# При первом старте создаст админа если ни одного нет (идемпотентно).
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# SP-2: native data
NATIVE_DATA_DIR=./data/native
MAX_DATASET_BYTES=524288000
MAX_ARTIFACT_BYTES=26214400
MAX_GRADER_BYTES=102400
MAX_GROUND_TRUTH_BYTES=524288000
